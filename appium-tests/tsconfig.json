{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@pages/*": ["pages/*"],
      "@utils/*": ["utilities/*"],
      "@data/*": ["test-data/*"],
      "@config/*": ["config/*"]
    },
    "types": ["node", "mocha", "@wdio/globals/types"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "reports"]
}
