{
  "name": "agridirect-appium-tests",
  "version": "1.0.0",
  "description": "Production-ready Appium automation framework for AgriDirect Android app",
  "scripts": {
    "test": "wdio run config/wdio.conf.ts",
    "test:auth": "wdio run config/wdio.conf.ts --spec tests/auth",
    "test:buyer": "wdio run config/wdio.conf.ts --spec tests/buyer",
    "test:farmer": "wdio run config/wdio.conf.ts --spec tests/farmer",
    "test:delivery": "wdio run config/wdio.conf.ts --spec tests/delivery",
    "test:e2e": "wdio run config/wdio.conf.ts --spec tests/e2e",
    "test:ci": "wdio run config/wdio.ci.conf.ts",
    "report:html": "ts-node utilities/generateHtmlReport.ts",
    "report:excel": "ts-node utilities/generateExcelReport.ts",
    "report:pdf": "ts-node utilities/generatePdfReport.ts",
    "report:all": "npm run report:html && npm run report:excel && npm run report:pdf"
  },
  "dependencies": {
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/allure-reporter": "^9.0.0",
    "appium": "^2.5.0",
    "appium-uiautomator2-driver": "^3.0.0",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.2.0",
    "moment": "^2.30.1",
    "pdfkit": "^0.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7"
  }
}
